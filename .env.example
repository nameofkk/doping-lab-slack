# 이 파일을 .env 로 복사해서 채우세요 (.env 는 gitignore). 발급법은 SETUP.md.
SLACK_BOT_TOKEN=xoxb-...        # OAuth & Permissions → Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...        # Socket Mode App-Level Token (connections:write)

# 봇이 작업할 폴더 (기본: 홈). 특정 프로젝트면 그 경로로.
WORKDIR=/home/krshin7/Projects

# claude 권한 모드: acceptEdits(기본,편집 자동승인) | bypassPermissions(완전자동·주의) | default
CLAUDE_PERMISSION_MODE=acceptEdits

# (선택) 이 Slack 유저ID들만 봇 사용 허용 (콤마구분). 비우면 전체 허용.
ALLOWED_SLACK_USER_IDS=

# (선택) 모델 고정 (비우면 기본)
CLAUDE_MODEL=
